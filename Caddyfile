# Caddyfile for General Bots Website
# Handles language-prefixed URLs for i18n
# 
# Language detection: JavaScript reads URL path (/pt/, /es/, etc.)
# and applies translations from /lang/{lang}.json
#
# All language URLs serve the same content, but with different translations applied client-side

{
    # Global options
    auto_https on
    email your-email@example.com  # Replace with actual email for Let's Encrypt
}

# Production domains
generalbots.org, www.generalbots.org {
    root * /home/ubuntu/src/generalbots.org
    
    # Language-prefixed URLs: /pt/, /es/, /fr/, /de/, /ja/, /zh-cn/
    # These are handled by serving content from root
    # JavaScript detects language from URL and applies translations
    
    # Try to serve the requested file, or fall back to index.html
    # This allows /pt/features/ to serve the same content as /features/
    try_files {path} {path}/ /index.html
    
    # Serve static files
    file_server
    
    # Compression
    encode gzip
    
    # TLS
    tls {
        protocols tls1.2 tls1.3
    }
    
    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }
}

# Local development
localhost:8080 {
    root * /home/ubuntu/src/generalbots.org
    
    try_files {path} {path}/ /index.html
    
    file_server
    encode gzip
}
